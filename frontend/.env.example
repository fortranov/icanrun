# Backend API URL (used by Next.js rewrites and direct server-side calls)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Application name
NEXT_PUBLIC_APP_NAME=ICanRun

# Google OAuth (only needed if GOOGLE_OAUTH_ENABLED=true in backend)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# YooKassa return URL
NEXT_PUBLIC_YOOKASSA_RETURN_URL=http://localhost:3000/settings?payment=success
